# 复制此文件为 .env 后填写真实值，仅用于本地测试。
# 真实部署使用 GitHub Actions Secrets，不要把真实值提交进 git。

# Bot 父亲（@BotFather）发给你的 token，长得像 7878787878:AAEabcdefghijklmnop
TELEGRAM_BOT_TOKEN=请把@fbuilders_bot的Token粘到这里

# 多个 chat_id 用英文逗号分隔。这里填你想接收推送的 Telegram 用户/群组 ID。
TELEGRAM_CHAT_IDS=6305691957,7371196144

# 可选：单次运行最多推送的新帖数（防止首次大量补发）。默认 8。
MAX_NEW_PER_RUN=8

# 可选：日志级别。默认 INFO。
LOG_LEVEL=INFO
